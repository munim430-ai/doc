{
  "name": "folio-v2",
  "version": "2.0.0",
  "description": "Keystone Education Consultancy — Document Generation Tool",
  "productName": "Folio",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "electron .",
    "build:template": "node scripts/buildTemplate.js",
    "build:excel": "node scripts/buildExcel.js",
    "build": "electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "docxtemplater": "^3.50.0",
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "find-free-port": "^2.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pizzip": "^3.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.keystoneedu.folio",
    "productName": "Folio",
    "copyright": "Copyright © 2025 Keystone Education Consultancy",
    "win": {
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Folio",
      "deleteAppDataOnUninstall": false
    },
    "files": [
      "electron/**/*",
      "services/**/*",
      "utils/**/*",
      "public/**/*",
      "universities/**/*",
      "server.js",
      "bundledAssets.js",
      "package.json",
      "node_modules/**/*",
      "!node_modules/.bin",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "universities",
        "to": "universities",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "compression": "normal",
    "asar": true,
    "publish": {
      "provider": "github",
      "owner": "munim430-ai",
      "repo": "doc"
    }
  }
}
